# Copy this file to `.env` and fill the real values.
# This file is for development only; do not commit real secrets.

APP_ENV=development
# Must be a full URL (include http:// or https://). Host-only breaks links on Railway.
BASE_URL=http://localhost:8000/

# Database (Aiven MySQL, Railway TCP proxy, etc.)
# Railway web (inside the platform): DB_HOST can be mysql.railway.internal (or ${{MySQL.MYSQLHOST}}).
#
# CLI on your laptop (setup_db.php, admin_seed.php): that internal host does NOT resolve locally.
# Set the public TCP proxy from Railway → MySQL → Connect (either form works in CLI):
#   DB_PUBLIC_HOST=xxxx.proxy.rlwy.net
#   DB_PUBLIC_PORT=12345
# Or paste the full URL from Connect:
#   DB_PUBLIC_HOST=mysql://root:PASSWORD@xxxx.proxy.rlwy.net:PORT/railway
# One-shot import + admin: ./database/bootstrap_from_cli.sh all
DB_HOST=hostelease-hostelease.a.aivencloud.com
DB_PORT=19887
DB_NAME=defaultdb
DB_USER=avnadmin
# Put your Aiven MySQL password here
DB_PASS=YOUR_DB_PASSWORD_HERE
DB_SSL=false

# Optional: enable super-admin "virtual login" fallback.
# If you seed a real `super_admin` user in DB, you can omit this.
SUPER_ADMIN_PASS_HASH=YOUR_SUPER_ADMIN_PASSWORD_BCRYPT_HASH_HERE

